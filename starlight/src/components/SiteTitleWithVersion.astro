---
import Default from "@astrojs/starlight/components/SiteTitle.astro";
import { getCollection } from "astro:content";

// Build a {version: Set<pathAfterVersion>} index from the docs collection
// so the switcher can ask "does v2 also have `the-basics/forms`?" at
// render time. getCollection is cached per build, so this runs once.
const allEntries = await getCollection("docs");
const slugsByVersion: Record<string, Set<string>> = {};
for (const entry of allEntries) {
  const m = entry.id.match(/^(v\d+)\/(.+)$/);
  if (!m) continue;
  const [, version, rest] = m;
  (slugsByVersion[version] ??= new Set()).add(rest);
}

const versions = [
  { slug: "v3", label: "v3.x" },
  { slug: "v2", label: "v2.x" },
  { slug: "v1", label: "v1.x" },
];

// Detect current version + path-after-version from the URL.
//   /docs/v2/the-basics/forms/  →  version "v2", path "the-basics/forms"
//   /docs/v2/                   →  version "v2", path ""
//   /docs/                      →  version null, path ""
const pathMatch = Astro.url.pathname.match(/^\/docs\/(v\d+)(?:\/(.*))?$/);
const currentVersion = pathMatch?.[1] ?? "v3";
const currentPath = (pathMatch?.[2] ?? "").replace(/\/$/, "");

const currentLabel =
  versions.find((v) => v.slug === currentVersion)?.label ?? "v3.x";

// Resolve the link for each version: keep the same path if the target
// version has it, otherwise fall back to that version's intro page.
const fallback = (v: string) => `/docs/${v}/getting-started/`;
const hrefFor = (v: string) => {
  if (!currentPath) return fallback(v);
  if (slugsByVersion[v]?.has(currentPath)) return `/docs/${v}/${currentPath}/`;
  return fallback(v);
};
---

<div class="site-title-wrap">
  <Default><slot /></Default>
  <div class="version-switcher">
    <button
      type="button"
      class="version-switcher__button"
      aria-haspopup="listbox"
      aria-expanded="false"
      data-version-button
    >
      <span>{currentLabel}</span>
      <svg
        width="10"
        height="10"
        viewBox="0 0 16 16"
        aria-hidden="true"
        fill="currentColor"
      >
        <path d="M4.427 6.427l3.396 3.396a.25.25 0 00.354 0l3.396-3.396A.25.25 0 0011.396 6H4.604a.25.25 0 00-.177.427z"></path>
      </svg>
    </button>
    <ul class="version-switcher__menu" role="listbox" data-version-menu hidden>
      {
        versions.map((v) => (
          <li>
            <a
              href={hrefFor(v.slug)}
              class={`version-switcher__item ${v.slug === currentVersion ? "version-switcher__item--active" : ""}`}
            >
              {v.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<script>
  // The Starlight header clips overflow, so position the menu with
  // `position: fixed` and compute top/left from the button's bounding rect.
  // Re-run on every `astro:page-load` because ClientRouter swaps the DOM
  // on navigation and the previous listeners are bound to a stale button.
  let controller: AbortController | null = null;
  const setup = () => {
    controller?.abort();
    const btn = document.querySelector<HTMLButtonElement>("[data-version-button]");
    const menu = document.querySelector<HTMLElement>("[data-version-menu]");
    if (!btn || !menu) return;
    controller = new AbortController();
    const { signal } = controller;
    const place = () => {
      const rect = btn.getBoundingClientRect();
      menu.style.top = `${rect.bottom + 4}px`;
      menu.style.left = `${rect.left}px`;
    };
    const toggle = (open: boolean) => {
      if (open) place();
      menu.hidden = !open;
      btn.setAttribute("aria-expanded", String(open));
    };
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      toggle(menu.hidden);
    }, { signal });
    document.addEventListener("click", (e) => {
      if (!menu.contains(e.target as Node) && e.target !== btn) toggle(false);
    }, { signal });
    window.addEventListener("scroll", () => toggle(false), { passive: true, signal });
    window.addEventListener("resize", () => toggle(false), { signal });
  };
  setup();
  document.addEventListener("astro:page-load", setup);
</script>
